# ============================================================
# emdb — .gitignore
# ============================================================

# --- Variables d'environnement ---
.env
.env.local
.env.*.local
!.env.example

# --- Dependances ---
node_modules/
.pnp
.pnp.js

# --- Build / output ---
dist/
build/
out/
.next/
.nuxt/
.turbo/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Tests / coverage ---
coverage/
.nyc_output/

# --- Cache ---
.cache/
.eslintcache

# --- OS ---
.DS_Store
Thumbs.db

# --- Editeurs / IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp

# --- Next.js specifique ---
.vercel

# --- NestJS / TypeScript ---
*.tsbuildinfo

# --- Supabase CLI (local dev) ---
supabase/.branches
supabase/.temp

# --- Divers ---
*.pem
.env.vault
