# ------------------------------------------------------------
# BASE DE DONNEES — DEV LOCAL (docker-compose : service `postgres`)
# ------------------------------------------------------------
# Utilisé par Prisma (packages/db) et par l'API/worker en local.
# En docker-compose, `postgres` est le nom du service (résolu sur le réseau interne) ;
# en local hors docker, utiliser `localhost`.
DATABASE_URL=postgresql://emdb:emdb@localhost:5432/emdb

# ------------------------------------------------------------
# SUPABASE (staging / prod managée — cf. roadmap, alternative à la Phase 1)
# ------------------------------------------------------------
# URL et clés dispo dans : Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Connexion directe Postgres (Project Settings > Database > Connection string)
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ------------------------------------------------------------
# TMDB
# ------------------------------------------------------------
# Clé API v3 (dispo dans : compte TMDB > Settings > API)
TMDB_API_KEY=
# Token v4 (Bearer, optionnel selon les endpoints utilisés)
TMDB_ACCESS_TOKEN=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ------------------------------------------------------------
# REDIS — DEV LOCAL (docker-compose : service `redis`)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Utilisé seulement en prod managée (ex: Upstash), laisser vide en local
REDIS_TOKEN=

# ------------------------------------------------------------
# BACKEND (NestJS)
# ------------------------------------------------------------
PORT=3001
NODE_ENV=development
JWT_SECRET=changeme-en-local-uniquement
# Doit correspondre à la config Supabase Auth si vérification JWT côté NestJS
JWT_ISSUER=

# ------------------------------------------------------------
# FRONTEND (Next.js)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001
