{
  "name": "@emdb/tmdb-sync",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest"
  },
  "dependencies": {
    "@emdb/tmdb-client": "*",
    "@emdb/tmdb-mapper": "*",
    "@emdb/wikidata-client": "*",
    "@emdb/db": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "moduleNameMapper": {
      "^@emdb/db$": "<rootDir>/../db/index.ts",
      "^@emdb/tmdb-client$": "<rootDir>/../tmdb-client/src/index.ts",
      "^@emdb/tmdb-mapper$": "<rootDir>/../tmdb-mapper/src/index.ts",
      "^@emdb/wikidata-client$": "<rootDir>/../wikidata-client/src/index.ts"
    },
    "testRegex": "src/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
